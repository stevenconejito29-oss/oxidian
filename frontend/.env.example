# Copia este archivo como .env y rellena con tus claves de Supabase
# Las encuentras en: supabase.com → tu proyecto → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxx
APP_SESSION_TTL_HOURS=8

# Servidor local del chatbot de WhatsApp
VITE_LOCAL_CHATBOT_URL=http://localhost:3001
VITE_LOCAL_CHATBOT_PORT=3001
VITE_LOCAL_CHATBOT_SECRET=pon_aqui_tu_clave_local
VITE_LOCAL_BACKEND_URL=http://127.0.0.1:5000
VITE_PUBLIC_WEB_URL=https://tu-dominio-publico.com
VITE_ALLOW_WEB_ADMIN=false

# Número de WhatsApp del negocio (con código de país, sin + ni espacios)
VITE_WHATSAPP_NUMBER=34622663874

# Solo para scripts Node locales y QA. NO se expone al frontend.
# OXIDIAN_ADMIN_PASSWORD=

# SEGURIDAD: NO usar VITE_ADMIN_PASSWORD — las variables VITE_* son públicas en el bundle JS.
# La contraseña del admin se guarda como hash SHA-256 en Supabase:
#   tabla: settings | clave: admin_password_hash | valor: <sha256 de tu password>
# Genera el hash: https://emn178.github.io/online-tools/sha256.html

# PWA Push Notifications (VAPID) — genera en: https://web-push-codelab.glitch.me/
VITE_VAPID_PUBLIC_KEY=

VITE_OXIDIAN_ENTRY_SLUG=nexo-control
OXIDIAN_TEMPLATE_STORE_ID=default
VITE_OXIDIAN_TEMPLATE_STORE_ID=default

# El backend privado vive en backend/.env
# Ahi van service_role, jwt secret, SMTP, Stripe y Resend.
